# RegLens environment variables
# Copy this file to .env and fill in your values.
# Never commit .env — it is in .gitignore.

# ---------------------------------------------------------------------------
# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=change-me

# ---------------------------------------------------------------------------
# Database (Postgres + pgvector)
# docker-compose default:
DATABASE_URL=postgresql+psycopg://reglens:reglens@localhost:5432/reglens
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ---------------------------------------------------------------------------
# LLM providers
GEMINI_API_KEY=          # Google AI Studio key — https://aistudio.google.com
ANTHROPIC_API_KEY=       # Anthropic API key — https://console.anthropic.com

# Model overrides (optional — defaults are set in config.py)
# GEMINI_INGESTION_MODEL=gemini-2.5-pro
# GEMINI_RISK_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=text-embedding-004
# CLAUDE_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# A2A agent endpoints
# These match the service names in docker-compose.yml
A2A_INGESTION_URL=http://reglens-adk-ingest:8001
A2A_RISK_SCORER_URL=http://reglens-adk-risk:8002
A2A_TIMEOUT_SECONDS=120
A2A_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# Observability
# LangSmith (leave blank to disable tracing)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=reglens
LANGSMITH_TRACING_ENABLED=false

# OpenTelemetry collector (leave blank to use console exporter)
OTEL_EXPORTER_ENDPOINT=
OTEL_SERVICE_NAME=reglens
